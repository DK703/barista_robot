<?xml version="1.0"?>
<robot name="barista">
        
  <material name="red">
      <color rgba="1.0 0.0 0.0 1"/>
  </material>

  <material name="green_light">
      <color rgba="0.0 1.0 0.0 1"/>
  </material>

  <material name="green_dark">
    <color rgba="0.0 0.5 0.0 1"/>
  </material>

  <material name="yellow">
      <color rgba="1.0 1.0 0.0 1"/>
  </material>

  <material name="blue">
      <color rgba="0.0 0.0 1.0 1"/>
  </material>

  <link name="base_link">


  </link>


  <!-- Body -->
  <link name="chassis">
    <visual>
      <geometry>
        <cylinder length="0.155" radius="0.178"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.155" radius="0.178"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0008333333333333335" ixy="0" ixz="0" iyy="0.0008333333333333335" iyz="0" izz="0.0008333333333333335"/>
    </inertial>

  </link>


<link name="left_wheel">
  <visual>
    <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.0206" radius="0.0352"/>
    </geometry>
  </visual>
  <collision>
    <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.0206" radius="0.0352"/>
    </geometry>
  </collision>
  <inertial>
    <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    <mass value="0.05"/>
    <inertia ixx="1.86e-05" ixy="0.0" ixz="0.0"
             iyy="1.86e-05" iyz="0.0"
             izz="3.10e-05"/>
  </inertial>
  <material name="yellow"/>
</link>

<link name="right_wheel">
  <visual>
    <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.0206" radius="0.0352"/>
    </geometry>
  </visual>
  <collision>
    <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.0206" radius="0.0352"/>
    </geometry>
  </collision>
  <inertial>
    <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    <mass value="0.05"/>
    <inertia ixx="1.86e-05" ixy="0.0" ixz="0.0"
             iyy="1.86e-05" iyz="0.0"
             izz="3.10e-05"/>
  </inertial>
  <material name="yellow"/>
</link>

  <joint name="base_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="base_link" />
    <child link="chassis" />
  </joint>

<joint name="joint_left_wheel" type="continuous">
    <origin rpy="0 0 0" xyz="0 0.125 -0.0884"/>
    <child link="left_wheel"/>
    <parent link="chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    
  </joint>

<joint name="joint_right_wheel" type="continuous">
    <origin rpy="0 0 0" xyz="0 -0.125 -0.0884"/>
    <child link="right_wheel"/>
    <parent link="chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    
  </joint>

<link name = "left_cone">
<visual>
      <geometry>
        <cylinder length="0.220" radius="0.010"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.220" radius="0.010"/>
      </geometry>
    </collision>
</link>

<joint name = "left_cone_joint" type = "fixed">
    <origin rpy="0 0 0" xyz="0.07 0.135 0.1875"/>
    <child link="left_cone"/>
    <parent link="chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
</joint>

<link name = "right_cone">
<visual>
      <geometry>
        <cylinder length="0.220" radius="0.010"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.220" radius="0.010"/>
      </geometry>
    </collision>
</link>

<joint name = "right_cone_joint" type = "fixed">
    <origin rpy="0 0 0" xyz="0.07 -0.135 0.1875"/>
    <child link="right_cone"/>
    <parent link="chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
</joint>

<link name = "left_cone2">
<visual>
      <geometry>
        <cylinder length="0.220" radius="0.010"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.220" radius="0.010"/>
      </geometry>
    </collision>
</link>

<joint name = "left_cone_joint2" type = "fixed">
    <origin rpy="0 0 0" xyz="-0.07 0.135 0.1875"/>
    <child link="left_cone2"/>
    <parent link="chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
</joint>


<link name = "right_cone2">
<visual>
      <geometry>
        <cylinder length="0.220" radius="0.010"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.220" radius="0.010"/>
      </geometry>
    </collision>
</link>

<joint name = "right_cone_joint2" type = "fixed">
    <origin rpy="0 0 0" xyz="-0.07 -0.135 0.1875"/>
    <child link="right_cone2"/>
    <parent link="chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
</joint>


<link name = "cup_holder">
<visual>
      <geometry>
        <cylinder length="0.090" radius="0.160"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.090" radius="0.160"/>
      </geometry>
    </collision>
</link>

<joint name = "top" type = "fixed">
    <origin rpy="0 0 0" xyz="0 0 0.340"/>
    <child link="cup_holder"/>
    <parent link="chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
</joint>


  <!--caster -->

  <link name="yaw_link">
    <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
        <material name="blue"/>
      </visual>


      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
      </collision>


      <inertial>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <mass value="0.001"/>
          <inertia ixx="5.145833333333334e-09" ixy="0" ixz="0" iyy="5.145833333333334e-09" iyz="0" izz="1.0125000000000003e-08"/>
      </inertial>
  </link>




  <joint name="yaw_joint" type="continuous">
    <origin rpy="0 0 0" xyz="-0.12 0 -0.086" />
    <parent link="chassis" />
    <child link="yaw_link" />
    <axis xyz="0 0 1" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>


  <link name="roll_link">
      <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
        <material name="red"/>
      </visual>


      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
      </collision>


      <inertial>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <mass value="0.001"/>
          <inertia ixx="5.145833333333334e-09" ixy="0" ixz="0" iyy="5.145833333333334e-09" iyz="0" izz="1.0125000000000003e-08"/>
      </inertial>
  </link>


  <joint name="roll_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="yaw_link" />
    <child link="roll_link" />
    <axis xyz="1 0 0" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>




  <link name="pitch_link">
    <visual>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.0368"/>
      </geometry>
      <material name="green_light"/>
    </visual>


    <collision>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.0368"/>
      </geometry>
    </collision>


    <inertial>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <mass value="0.001"/>
        <inertia ixx="4e-08" ixy="0" ixz="0" iyy="4e-08" iyz="0" izz="4e-08"/>
    </inertial>
  </link>


  <gazebo reference="pitch_link">
    <collision>
        <surface>
        <friction>
            <ode>
            <mu>0.05</mu>
            <mu2>0.05</mu2>
            </ode>
        </friction>
        <contact>
            <ode>
            <kp>100000.0</kp>
            <kd>1000.0</kd>
            </ode>
        </contact>
        </surface>
    </collision>
  </gazebo>


  <joint name="pitch_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="roll_link" />
    <child link="pitch_link" />
    <axis xyz="0 1 0" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>


<link name="yaw_link2">
    <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
        <material name="blue"/>
      </visual>


      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
      </collision>


      <inertial>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <mass value="0.001"/>
          <inertia ixx="5.145833333333334e-09" ixy="0" ixz="0" iyy="5.145833333333334e-09" iyz="0" izz="1.0125000000000003e-08"/>
      </inertial>
  </link>


  <joint name="yaw_joint2" type="continuous">
    <origin rpy="0 0 0" xyz="0.12 0 -0.086" />
    <parent link="chassis" />
    <child link="yaw_link2" />
    <axis xyz="0 0 1" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>

<link name="roll_link2">
      <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
        <material name="red"/>
      </visual>


      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
      </collision>


      <inertial>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <mass value="0.001"/>
          <inertia ixx="5.145833333333334e-09" ixy="0" ixz="0" iyy="5.145833333333334e-09" iyz="0" izz="1.0125000000000003e-08"/>
      </inertial>
  </link>


  <joint name="roll_joint2" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="yaw_link2" />
    <child link="roll_link2" />
    <axis xyz="1 0 0" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>


  <link name="pitch_link2">
    <visual>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.0368"/>
      </geometry>
      <material name="green_light"/>
    </visual>


    <collision>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.0368"/>
      </geometry>
    </collision>


    <inertial>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <mass value="0.001"/>
        <inertia ixx="4e-08" ixy="0" ixz="0" iyy="4e-08" iyz="0" izz="4e-08"/>
    </inertial>
  </link>


  <gazebo reference="pitch_link2">
    <collision>
        <surface>
        <friction>
            <ode>
            <mu>0.05</mu>
            <mu2>0.05</mu2>
            </ode>
        </friction>
        <contact>
            <ode>
            <kp>100000.0</kp>
            <kd>1000.0</kd>
            </ode>
        </contact>
        </surface>
    </collision>
  </gazebo>


  <joint name="pitch_joint2" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="roll_link2" />
    <child link="pitch_link2" />
    <axis xyz="0 1 0" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>


  <!-- Differential Drive Plugin -->
<gazebo>
    <plugin
        filename="gz-sim-diff-drive-system"
        name="gz::sim::systems::DiffDrive">
        <left_joint>joint_left_wheel</left_joint>
        <right_joint>joint_right_wheel</right_joint>
        <wheel_separation>0.1</wheel_separation>
        <wheel_radius>0.035</wheel_radius>
        <topic>cmd_vel</topic>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>
        <odom_topic>odom</odom_topic>
        <tf_topic>tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
    </plugin>
</gazebo>

 

  
  




</robot>